theme: /

    state: hello
        intent!: /hello
        q!: *привет*
        q!: *приветик*
        q!: *здравствуй*
        q!: *здравствуйте*
        q!: *добрый день*
        q!: *доброе утро*
        q!: *добрый вечер*
